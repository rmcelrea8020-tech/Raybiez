function getVariant(tribe) {

  if (chance(.3)) return "None";

  return random(variants[tribe] || ["None"]);

}

function generateDragon() {

  let typeRoll = Math.random();

  let type = "Pure";

  let tribe1 = random(tribes);

  let tribe2 = null;

  if (typeRoll < 0.55) {

    type = "Pure";

  }

  else if (typeRoll < 0.9) {

    type = "Hybrid";

    tribe2 = random(tribes);

  }

  else {

    type = "Tribred";

    tribe2 = random(tribes);

  }

  let tribeText = tribe1;

  if (tribe2) tribeText += " + " + tribe2;

  let variant = getVariant(tribe1);

  let age = random(ages);

  let gender = random(genders);

  let mutationRoll = Math.random();

  let mutationCount = 0;

  if (mutationRoll < 0.4) mutationCount = 0;

  else if (mutationRoll < 0.7) mutationCount = 1;

  else if (mutationRoll < 0.9) mutationCount = 2;

  else mutationCount = 3;

  let pool = [...universalMutations];

  if (tribeMutations[tribe1]) pool = pool.concat(tribeMutations[tribe1]);

  if (type != "Pure") pool = pool.concat(hybridMutations);

  let chosen = [];

  for (let i = 0; i < mutationCount; i++) {

    chosen.push(random(pool));

  }

  let html = "";

  chosen.forEach(m => {

    html += `<div class="mutation"><b>${m.name}</b> — ${m.desc}</div>`;

  });

  if (html === "") html = "None";

  document.getElementById("tribe").innerText = tribeText;

  document.getElementById("type").innerText = type;

  document.getElementById("subspecies").innerText = variant;

  document.getElementById("age").innerText = age;

  document.getElementById("gender").innerText = gender;

  document.getElementById("mutations").innerHTML = html;

}
